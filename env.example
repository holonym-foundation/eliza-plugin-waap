# WaaP plugin configuration. Set these in your agent's environment or character file.

# Per-agent session directory. The plugin auto-derives this from runtime.agentId
# if unset. Operator MUST run `waap-cli login` into this directory before starting
# the agent — see README for provisioning steps.
# WAAP_CLI_SESSION_DIR=/home/user/.eliza/my-agent-id/waap

# Default EVM chain id for actions that don't specify one explicitly (v1 is EVM-only).
# Defaults to 1 (Ethereum mainnet) if unset.
# WAAP_DEFAULT_CHAIN_ID=137

# Default RPC URL for the configured chain.
# WAAP_DEFAULT_RPC_URL=https://polygon-rpc.com

# Optional: pre-issued permission tokens to bypass 2FA for specific chains.
# Key format: WAAP_PERMISSION_TOKEN_<chainId>. Treat as secrets.
# WAAP_PERMISSION_TOKEN_137=eyJhbGc...

# Optional: override for waap-cli binary location (escape hatch for unusual installs).
# WAAP_CLI_BINARY=/usr/local/bin/waap-cli

# Optional: target backend environment (development or production).
# SILK_NODE_ENV=production
